{
  "name": "tabby-voice-dictation",
  "version": "0.1.0",
  "description": "Voice dictation plugin for Tabby terminal with hotkey-triggered speech-to-terminal input.",
  "keywords": ["tabby-plugin", "tabby", "terminal", "voice", "dictation", "speech-to-text"],
  "license": "MIT",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "npm run typecheck",
    "package": "npm pack"
  },
  "peerDependencies": {
    "tabby-core": "*",
    "tabby-terminal": "*",
    "tabby-settings": "*"
  },
  "devDependencies": {
    "@angular/core": "^17.0.0",
    "@types/node": "^20.0.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^6.8.0",
    "eslint": "^8.56.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
