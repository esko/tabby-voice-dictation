{
  "name": "tabby-voice-dictation",
  "version": "0.1.0",
  "description": "Voice dictation plugin for Tabby terminal with hotkey-triggered speech-to-terminal input.",
  "keywords": [
    "tabby-plugin",
    "tabby",
    "terminal",
    "voice",
    "dictation",
    "speech-to-text"
  ],
  "license": "MIT",
  "author": "Antigravity",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "npm run typecheck && npx tsc --module commonjs --outDir dist-test && node --test 'dist-test/test/*.test.js'",
    "package": "npm pack"
  },
  "peerDependencies": {
    "tabby-core": "*",
    "tabby-settings": "*",
    "tabby-terminal": "*"
  },
  "devDependencies": {
    "@angular/animations": "15.2.10",
    "@angular/common": "15.2.10",
    "@angular/core": "15.2.10",
    "@angular/forms": "15.2.10",
    "@angular/platform-browser": "15.2.10",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^6.8.0",
    "eslint": "^8.56.0",
    "style-loader": "^3.3.4",
    "tabby-core": "1.0.231-nightly.0",
    "tabby-settings": "1.0.231-nightly.0",
    "tabby-terminal": "1.0.231-nightly.0",
    "ts-loader": "^9.5.1",
    "typescript": "~4.9.5",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
